# Базы данных (если используете локальные файлы БД)
*.db
*.sqlite
*.sqlite3

# Alembic (миграции базы данных) - оставляем только файлы миграций,
# но игнорируем временные файлы
alembic/versions/*.pyc
alembic/versions/__pycache__/

